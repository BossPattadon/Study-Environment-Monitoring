    {
        "id": "cd34693b52774540",
        "type": "function",
        "z": "50d099b7335b2b4a",
        "name": "Function (format)",
        "func": "// ── ตรวจ payload ──\nif (!msg.payload) {\n    node.error(\"No data from OpenWeather\");\n    return null;\n}\n\nlet data = msg.payload;\n\n// ── ดึงค่า ──\nlet temp = data.main.temp;\nlet humidity = data.main.humidity;\nlet pressure = data.main.pressure;\nlet wind = data.wind.speed;\n\nlet weather_main = data.weather[0].main;\nlet weather_desc = data.weather[0].description;\n\n// ── timestamp (unix → MySQL) ──\nlet dt = new Date(data.dt * 1000);\nlet mysqlTime = dt.toISOString().slice(0, 19).replace('T', ' ');\n\n// ── payload สำหรับ MySQL ──\nmsg.payload = [\n    temp,\n    humidity,\n    pressure,\n    wind,\n    weather_main,\n    weather_desc,\n    mysqlTime\n];\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 570,
        "y": 500,
