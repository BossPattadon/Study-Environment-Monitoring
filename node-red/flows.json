    {
        "id": "9035961da354651c",
        "type": "function",
        "z": "50d099b7335b2b4a",
        "name": "Insert",
        "func": "const rows = msg.payload;\n\nif (!rows || rows.length === 0) return null;\n\n// Take only the latest row\nconst row = rows[0];\n\nmsg.topic = `\n    INSERT IGNORE INTO openaq\n        (sensor_id, value, units, aqi_label, timestamp_local, timestamp_utc, has_flags)\n    VALUES (?, ?, ?, ?, ?, ?, ?)\n`;\n\nmsg.payload = [\n    row.sensor_id,\n    row.value,\n    row.units,\n    row.aqi_label,\n    row.timestamp_local,\n    row.timestamp_utc,\n    row.has_flags\n];\n\nnode.log(\"Inserting 1 row: \" + row.timestamp_local + \" PM2.5=\" + row.value);\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
