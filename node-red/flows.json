    {
        "id": "965bdee8d0c3be3b",
        "type": "function",
        "z": "50d099b7335b2b4a",
        "name": "Function (format)",
        "func": "let d = msg.payload.data;\n\nlet pollution = d.current.pollution;\nlet weather = d.current.weather;\n\nlet dt = new Date(); // IQAir free ไม่มี timestamp\nlet mysqlTime = dt.toISOString().slice(0, 19).replace('T', ' ');\n\nmsg.payload = [\n    pollution.aqius,\n    pollution.mainus,\n    null, null, null, null, null, null,   // pm25, pm10 etc (optional)\n\n    weather.tp,\n    weather.hu,\n    weather.pr,\n    weather.ws,\n    weather.wd,\n\n    d.city,\n    d.country,\n\n    mysqlTime\n];\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
