    {
        "id": "c0be3b1d6455b46e",
        "type": "function",
        "z": "50d099b7335b2b4a",
        "name": "Parse",
        "func": "const results = msg.payload.results;\n\nif (!results || results.length === 0) {\n    node.warn(\"No data received\");\n    return null;\n}\n\nfunction getAQILabel(pm25) {\n    if (pm25 <= 12) return \"Good\";\n    if (pm25 <= 35.4) return \"Moderate\";\n    if (pm25 <= 55.4) return \"Unhealthy for Sensitive Groups\";\n    if (pm25 <= 150.4) return \"Unhealthy\";\n    if (pm25 <= 250.4) return \"Very Unhealthy\";\n    return \"Hazardous\";\n}\n\nfunction toMySQL(isoStr) {\n    if (!isoStr) return null;\n    return isoStr.replace('T', ' ').substring(0, 19);\n}\n\nmsg.payload = results.map(item => ({\n    sensor_id: 1304409,\n    value: item.value,\n    units: item.parameter.units,\n    aqi_label: getAQILabel(item.value),\n    timestamp_local: toMySQL(item.period.datetimeTo.local),\n    timestamp_utc: toMySQL(item.period.datetimeTo.utc),\n    has_flags: item.flagInfo.hasFlags ? 1 : 0\n}));\n\nnode.log(\"Parsed \" + msg.payload.length + \" records\");\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
